{
  "name": "@vgrep/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "vgrep": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "build": "bun build --compile --minify --sourcemap=none ./src/cli.ts --outfile vgrep",
    "build:darwin-arm64": "bun build --compile --minify --sourcemap=none --target=bun-darwin-arm64 ./src/cli.ts --outfile dist/vgrep-darwin-arm64",
    "build:darwin-x64": "bun build --compile --minify --sourcemap=none --target=bun-darwin-x64 ./src/cli.ts --outfile dist/vgrep-darwin-x64",
    "build:linux-arm64": "bun build --compile --minify --sourcemap=none --target=bun-linux-arm64 ./src/cli.ts --outfile dist/vgrep-linux-arm64",
    "build:linux-x64": "bun build --compile --minify --sourcemap=none --target=bun-linux-x64 ./src/cli.ts --outfile dist/vgrep-linux-x64",
    "build:windows-x64": "bun build --compile --minify --sourcemap=none --target=bun-windows-x64 ./src/cli.ts --outfile dist/vgrep-windows-x64.exe",
    "build:all": "bun run build:darwin-arm64 && bun run build:darwin-x64 && bun run build:linux-arm64 && bun run build:linux-x64 && bun run build:windows-x64",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vgrep/core": "workspace:*",
    "effect": "^3.21.2"
  }
}
