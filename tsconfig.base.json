{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "lib": [
      "ESNext"
    ],
    "types": [
      "bun-types"
    ],
    "baseUrl": ".",
    "paths": {
      "@vgrep/core": [
        "./packages/core/src/index.ts"
      ],
      "@vgrep/cli": [
        "./packages/cli/src/cli.ts"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist"
  ]
}